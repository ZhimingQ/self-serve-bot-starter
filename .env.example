# ─────────────────────────────────────────────────────────────
# Branding — all values are read by lib/config.ts, no code edits needed
# ─────────────────────────────────────────────────────────────
BRAND_NAME=YourBrand
BRAND_ACCENT=#777e69
# Which OpenClaw Launch framework each new bot is provisioned with: openclaw | hermes
BOT_FRAMEWORK=openclaw

# ─────────────────────────────────────────────────────────────
# OpenClaw Launch "Build & Resell" API
# ─────────────────────────────────────────────────────────────
BUILD_RESELL_API_BASE=https://openclawlaunch.com/api/v1
# SERVER-SIDE ONLY SECRET. Get this from your Build & Resell dashboard.
# Never expose this to the browser / never prefix it with NEXT_PUBLIC_.
BUILD_RESELL_API_KEY=sk_live_replace_me

# ─────────────────────────────────────────────────────────────
# Session signing (hand-rolled, no auth library)
# ─────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_a_long_random_string

# ─────────────────────────────────────────────────────────────
# Persistence — Upstash Redis (REST API, no client library)
# If these are unset, the app falls back to an in-memory store
# (fine for local dev, NOT for production — data resets on every restart).
# ─────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─────────────────────────────────────────────────────────────
# Persistence — JSON-file store (alternative to Upstash)
# For a host with a persistent disk but no Redis (e.g. the "Deploy via your bot"
# path). Used only when Upstash is unset. Point ONE process at a given dir — do
# not run multiple processes against the same STORE_DIR (the JSON file has a
# single owner). Leave empty on Vercel/serverless; use Upstash there.
# ─────────────────────────────────────────────────────────────
STORE_DIR=

# ─────────────────────────────────────────────────────────────
# Payment — charge YOUR end users on YOUR OWN Stripe before a bot is
# provisioned (this is where your reseller margin lives). Leave STRIPE_SECRET_KEY
# and STRIPE_PRICE_ID unset to run in NO-PAYMENT mode (signup provisions a bot
# immediately — good for demoing before you wire Stripe).
# ─────────────────────────────────────────────────────────────
# Your Stripe secret key (sk_live_… in prod, sk_test_… to test). SERVER ONLY.
STRIPE_SECRET_KEY=
# The Stripe Price your customers buy (price_…). You set the amount + currency in
# your Stripe dashboard — your markup over the ~$6/deploy is yours.
STRIPE_PRICE_ID=
# "subscription" for a recurring price, "payment" for a one-time price. Must match
# the Price's type. Defaults to subscription.
STRIPE_MODE=subscription
# Webhook signing secret (whsec_…). From your dashboard webhook, or from
# `stripe listen --forward-to localhost:3000/api/stripe/webhook` while testing.
STRIPE_WEBHOOK_SECRET=
# Public base URL of THIS storefront — used for Stripe Checkout redirect URLs.
APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# Live demo mode — turn this storefront into a public, read-only showcase.
# When DEMO_MODE=1: signup + NEW bot provisioning are HARD-DISABLED (no visitor
# can create a real bot). Signup CTAs point at DEMO_SIGNUP_URL; existing users
# can still log in and chat with an already-provisioned assistant. Leave unset
# for a normal storefront. Use this when linking the storefront publicly.
# ─────────────────────────────────────────────────────────────
DEMO_MODE=
# Where the landing CTAs send visitors in demo mode (defaults to the OpenClaw
# Launch Templates page).
DEMO_SIGNUP_URL=https://openclawlaunch.com/developer-api/templates

# ─────────────────────────────────────────────────────────────
# Locale routing — optionally lock a deployment or host to one language.
# SITE_LOCALE=en or zh locks every hostname. Leave it unset to map individual
# hostnames below; comma-separated aliases are supported. Any unmatched host
# keeps the cookie-backed EN / 中文 switcher for local development and previews.
# ─────────────────────────────────────────────────────────────
SITE_LOCALE=
LOCALE_HOST_EN=
LOCALE_HOST_ZH=
